# ═══════════════════════════════════════════════════════════════════════════════
# OCDR — Medical Imaging Practice Management System
# Environment Configuration Template
# Copy to .env and fill in your values. NEVER commit the real .env file.
# ═══════════════════════════════════════════════════════════════════════════════

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development                     # development | production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
APP_SECRET_KEY=CHANGE_ME_use_secrets_token_hex_32  # python -c "import secrets; print(secrets.token_hex(32))"
APP_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://ocdr:ocdrpass@localhost:5432/ocdr_db
# For SQLite (development only): sqlite+aiosqlite:///./ocdr.db
DATABASE_ECHO=false

# ── Encryption ────────────────────────────────────────────────────────────────
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=CHANGE_ME_generate_with_fernet

# ── JWT Authentication ────────────────────────────────────────────────────────
JWT_SECRET_KEY=CHANGE_ME_use_secrets_token_hex_64
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
SESSION_IDLE_TIMEOUT_MINUTES=15

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Document Watcher Folders ──────────────────────────────────────────────────
WATCH_SCHEDULES_DIR=/data/schedules
WATCH_EOBS_DIR=/data/eobs
WATCH_PAYMENTS_DIR=/data/payments
BACKUP_DIR=/data/backups

# ── Matching Thresholds ───────────────────────────────────────────────────────
PATIENT_FUZZY_MATCH_THRESHOLD=85        # minimum score to link to existing patient
PATIENT_REVIEW_THRESHOLD=95            # below this → flagged for staff review
EOB_AUTO_POST_THRESHOLD=92             # minimum confidence to auto-post payment
PAYER_TEMPLATE_MIN_EXTRACTIONS=10      # successful extractions before template is generated

# ── Office Ally ───────────────────────────────────────────────────────────────
OFFICE_ALLY_BASE_URL=https://oa.officeally.com
OFFICE_ALLY_USERNAME=your_oa_username
OFFICE_ALLY_PASSWORD=your_oa_password
OFFICE_ALLY_SUBMITTER_ID=your_submitter_id
OFFICE_ALLY_SYNC_INTERVAL_HOURS=4

# ── Microsoft Purview ─────────────────────────────────────────────────────────
PURVIEW_ENABLED=false
PURVIEW_ENDPOINT=https://YOUR_ACCOUNT.purview.azure.com
PURVIEW_TENANT_ID=your-azure-tenant-id
PURVIEW_CLIENT_ID=your-azure-client-id
PURVIEW_CLIENT_SECRET=your-azure-client-secret
PURVIEW_COLLECTION=ocdr-phi-assets

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_ENABLED=true
BACKUP_CRON=0 2 * * *                  # daily at 2 AM
BACKUP_RETENTION_DAYS=30

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json                        # json | text
