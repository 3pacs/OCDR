# =============================================================================
# OCMRI Billing Reconciliation System - Environment Configuration
# Copy this file to .env and update values for your environment
# =============================================================================

# --- PostgreSQL ---
POSTGRES_DB=ocmri
POSTGRES_USER=ocmri
POSTGRES_PASSWORD=ocmri_secret
POSTGRES_PORT=5432

# --- Backend ---
BACKEND_PORT=8000
SECRET_KEY=change-me-in-production-use-a-random-64-char-string
ENVIRONMENT=development
LOG_LEVEL=info

# --- Frontend ---
FRONTEND_PORT=3000

# --- Data Directories (inside container, typically no need to change) ---
# DATA_DIR=/app/data
# EXCEL_DIR=/app/data/excel
# EOBS_DIR=/app/data/eobs
# SCHEDULES_DIR=/app/data/schedules
# PAYMENTS_DIR=/app/data/payments
# PROCESSED_DIR=/app/data/processed

# --- DuckDB (analytics engine, file-based, inside container) ---
# DUCKDB_PATH=/app/data/duckdb/analytics.duckdb

# --- Browser-assisted payer portal downloads ---
# Chrome keeps the portal auth; OCDR only stages files you download.
OCDR_PORTAL_URLS=https://www.officeally.com/Logout.aspx?Timeout=1;https://x02.officeally.com/auth0bridge/Logon?ReturnUrl=/secure_oa.asp;https://myservices.optumhealthpaymentservices.com/registrationSignIn.do;https://identity.onehealthcareid.com/oneapp/index.html#/login
OCDR_PORTAL_DOWNLOAD_DIR=C:\Users\YOUR_USER\Downloads
OCDR_PORTAL_STAGING_DIR=C:\Users\YOUR_USER\OCDR-portal-downloads\incoming
OCDR_PORTAL_STATE_DIR=C:\Users\YOUR_USER\AppData\Local\OCMRI\OCDRPortalDownloads
OCDR_PORTAL_DOWNLOAD_EXTENSIONS=.835,.edi,.txt,.dat,.era,.pdf,.csv,.xlsx,.xls,.zip
OCDR_PORTAL_MIN_AGE_SECONDS=15
OCDR_PORTAL_MAX_AGE_HOURS=72
OCDR_OFFICEALLY_RESET_DELAY_SECONDS=2
OCDR_SCANSNAP_HOST=anikd@ocr-node
OCDR_SCANSNAP_STATUS_TIMEOUT_SECONDS=8
# Linux Docker hosts can mount an SSH key directory so the backend can query ScanSnap status.
# Leave unset on nodes that do not need SSH-backed scanner status.
# OCDR_BACKEND_SSH_DIR=/home/grid/.ssh
# Optional Chrome profile overrides. Leave blank to use the current/default Chrome profile.
# OCDR_CHROME_PROFILE=Default
# OCDR_CHROME_USER_DATA_DIR=C:\Users\YOUR_USER\AppData\Local\Google\Chrome\User Data

# --- Browser validation portals ---
# Leave credentials blank until they are stored on the node that will run validation.
PAYER_PORTAL_URL=https://pm.officeally.com/pm/login.aspx
OFFICE_ALLY_USER=
OFFICE_ALLY_PASSWORD=
PACS_PORTAL_URL=
PURVIEW_USER=
PURVIEW_PASSWORD=
BANK_PORTAL_URL=
BANK_PORTAL_USER=
BANK_PORTAL_PASSWORD=

# --- Matching Thresholds ---
# FUZZY_MATCH_THRESHOLD=85
# AUTO_ACCEPT_CONFIDENCE=95
# REVIEW_CONFIDENCE_MIN=75
# MANUAL_CONFIRM_CONFIDENCE_MIN=50
